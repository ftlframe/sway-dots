{
  "layer": "bot",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 15,
  "position": "top",
  "margin-right": 100,
  "margin-left": 100,
  "modules-left": [
    "sway/workspaces",
    "custom/separator",
    "bluetooth",
    "custom/applauncher",
    "custom/separator#2",
    "mpris"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "custom/separator",
    "sway/language",
    "custom/separator#3",
    "network",
    "group/tray",
    "custom/separator#4",
    "pulseaudio",
    "idle_inhibitor",
    "custom/separator#5",
    "custom/dnd",
    "custom/powermenu",
    "battery"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "custom/separator": {
    "format": "│",
    "tooltip": false
  },
  "custom/separator#2": {
    "format": "│",
    "tooltip": false
  },
  "custom/separator#3": {
    "format": "│",
    "tooltip": false
  },
  "custom/separator#4": {
    "format": "│",
    "tooltip": false
  },
  "custom/separator#5": {
    "format": "│",
    "tooltip": false
  },
  "custom/separator#6": {
    "format": "│",
    "tooltip": false
  },
  "group/tray": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 300,
      "children-class": "drawer-child",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/tray-toggle",
      "tray"
    ]
  },
  "custom/tray-toggle": {
    "format": "",
    "tooltip": false
  },
  "clock": {
    "disable-scroll": true,
    "format": "{:%d %b  |  %H:%M:%S}",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "year",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#f5b0ef'><b>{}</b></span>",
        "days": "<span color='#8e6da6'><b>{}</b></span>",
        "weeks": "<span color='#9ccfd8'><b>W{}</b></span>",
        "weekdays": "<span color='#a29dfa'><b>{}</b></span>",
        "today": "<span color='#9ccfd8'><b><u>{}</u></b></span>"
      }
    },
    "interval": 1,
    "on-click": "gnome-calendar"
  },
  "cpu": {
    "format": " {usage}%",
    "interval": 5,
    "tooltip": false
  },
  "memory": {
    "format": " {percentage}%",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "{used:0.1f}G / {total:0.1f}G"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "󰅶",
      "deactivated": "󰛊"
    },
    "tooltip": true,
    "tooltip-format-activated": "Idle inhibitor: ON",
    "tooltip-format-deactivated": "Idle inhibitor: OFF"
  },
  "custom/dnd": {
    "format": "{}",
    "exec": "swaync-client -D 2>/dev/null && echo '󰂛' || echo '󰂚'",
    "on-click": "swaync-client -d",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "Toggle Do Not Disturb"
  },
  "custom/powermenu": {
    "format": "⏻",
    "on-click": "wlogout",
    "tooltip": false
  },
  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "󰂲",
    "format-connected": "󰂱 {num_connections}",
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false,
    "on-click": "blueman-manager"
  },
  "custom/applauncher": {
    "format": "",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },
  "network": {
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰈀 Wired",
    "format-disconnected": "󰤭 Off",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 150,
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5% && pactl set-sink-volume @DEFAULT_SINK@ 100% --",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "",
      "",
      ""
    ],
    "nospacing": 1,
    "format-muted": "",
    "on-click": "pavucontrol",
    "tooltip": false
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": " {capacity}%",
    "format-icons": [
      "",
      "",
      "",
      "",
      ""
    ],
    "states": {
      "warning": 20,
      "critical": 10
    },
    "interval": 10
  },
  "mpris": {
    "format": "{player_icon} {artist} - {title}",
    "format-paused": "{player_icon} {status_icon} {artist} - {title}",
    "player-icons": {
      "default": "▶"
    },
    "status-icons": {
      "paused": "⏸"
    },
    "max-length": 40,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": false
  },
  "sway/language": {
    "format": "󰌌 {}",
    "tooltip": false
  }
}